PORT=3001

# Provider: ytdlp | cobalt | rapidapi | mock
# Render production (Docker includes ffmpeg + yt-dlp automatically):
API_PROVIDER=ytdlp
YTDLP_PATH=python3 -m yt_dlp

# Cobalt (optional — self-hosted instance + API key)
# API_PROVIDER=cobalt
# COBALT_API_URL=https://your-cobalt-instance.com
# COBALT_API_KEY=your-api-key-here

# RapidAPI (paid)
# RAPIDAPI_KEY=your_rapidapi_key_here
# RAPIDAPI_HOST=social-media-video-downloader.p.rapidapi.com
